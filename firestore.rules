rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * UniTrack Campus Visitor System - Security Rules
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a robust Authorization-first model designed for high security and 
     * rapid iteration. It distinguishes between standard Visitors and Administrators, primarily 
     * using document ownership and a dedicated role-based collection.
     *
     * DATA STRUCTURE:
     * - /users/{userId}: Individual user profiles, owned by the user.
     * - /roles_admin/{adminId}: A lookup collection where the presence of a UID grants admin privileges.
     * - /user_sessions/{sessionId}: Top-level collection for real-time activity monitoring.
     * - /visits/{visitId}: Top-level collection for campus entry/exit records.
     *
     * KEY SECURITY DECISIONS:
     * - Authorization Independence: User-specific data in top-level collections (sessions, visits) 
     *   include a denormalized 'userId' field. This allows rules to verify ownership instantly 
     *   without performing expensive cross-document lookups (get() calls).
     * - Admin Dashboard Support: Administrators are granted global 'list' and 'get' access to 
     *   sessions and visits to support real-time dashboards and auditing.
     * - Ownership Immutability: Once a document is associated with a userId, that association 
     *   cannot be changed by a standard user, preventing data hijacking.
     * - Prototyping Flexibility: While access is strictly controlled, the rules do not enforce 
     *   strict schemas or data types, allowing developers to evolve the data model without 
     *   constant rules updates.
     */

    // --- Helper Functions ---

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the signed-in user exists in the admin roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** Checks if the provided ID matches the signed-in user's UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the signed-in user is the owner and the document exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** Checks ownership for documents where the owner ID is stored within the data field. */
    function isDocOwner(data) {
      return isSignedIn() && request.auth.uid == data.userId;
    }

    /** Checks ownership for updates/deletes where the existing document's userId must match the caller. */
    function isExistingDocOwner() {
      return resource != null && isDocOwner(resource.data);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profiles. Users can manage their own profile; admins can manage all.
     * @path /users/{userId}
     * @allow get: User matching {userId} or any Admin.
     * @deny list: Non-admin users attempting to list all system users.
     * @principle Enforces path-based ownership for private profile data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    /**
     * @description Role registry for administrators. Used for Database-Backed Access Control (DBAC).
     * @path /roles_admin/{adminId}
     * @allow get: Any signed-in user (required for the isAdmin() existence check to function).
     * @deny create, update, delete: Direct modification by users via the client SDK.
     * @principle Restricts role management to administrative interfaces/service accounts.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }

    /**
     * @description Tracks user login sessions for the real-time admin dashboard.
     * @path /user_sessions/{sessionId}
     * @allow create: Any user setting their own userId.
     * @allow update: Owner updating their session (e.g., logging out) or Admin.
     * @allow list: Administrators for real-time monitoring.
     * @principle Uses denormalized userId for fast, secure owner-validation and admin listing.
     */
    match /user_sessions/{sessionId} {
      allow get: if isAdmin() || isDocOwner(resource.data);
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if (isExistingDocOwner() || isAdmin()) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingDocOwner() || isAdmin();
    }

    /**
     * @description Records of individual campus visits.
     * @path /visits/{visitId}
     * @allow create: Any user logging their own visit.
     * @allow list: Administrators viewing campus traffic.
     * @deny delete: Standard users trying to remove visit history.
     * @principle Ensures relational integrity by locking the userId on creation.
     */
    match /visits/{visitId} {
      allow get: if isAdmin() || isDocOwner(resource.data);
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if (isExistingDocOwner() || isAdmin()) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAdmin();
    }
  }
}